{
  "name": "web-tools",
  "private": true,
  "scripts": {
    "test": "node --test 'tools/test/**/*.test.mjs'",
    "preview": "node tools/render/preview.mjs",
    "shot": "node tools/render/screenshot.mjs",
    "build": "node tools/build/build.mjs",
    "build:lib": "node tools/build/build-lib.mjs",
    "build:console": "node tools/build/console-suite.mjs",
    "bake": "node tools/build/bake.mjs",
    "verify-build": "node tools/build/verify-build.mjs",
    "pages-shots": "node tools/build/pages-shots.mjs",
    "pages-index": "node tools/build/pages-index.mjs",
    "pages": "npm run pages-shots && npm run pages-index",
    "wsl-fetch": "node pages/wsl-sync/fetch-data.mjs",
    "tracker-board": "python3 scripts/build-board.py tracker/tasks tracker/board.md",
    "sunset": "python3 scripts/sunset-scan.py --all"
  },
  "devDependencies": {
    "@alpinejs/collapse": "^3.15.12",
    "@alpinejs/sort": "^3.15.12",
    "@phosphor-icons/web": "^2.1.2",
    "@tailwindcss/browser": "^4.3.0",
    "@tailwindcss/typography": "^0.5.19",
    "acorn": "^8.11.3",
    "alpinejs": "^3.15.11",
    "brotli-wasm": "^3.0.0",
    "clipboard": "^2.0.11",
    "codemirror": "^5.65.21",
    "daisyui": "^5.5.20",
    "diff": "^5.2.2",
    "diff2html": "^3.4.56",
    "fake-indexeddb": "^6.2.5",
    "fast-xml-parser": "^4.5.1",
    "flat": "^6.0.0",
    "idb-keyval": "^6.2.2",
    "jquery": "^3.7.1",
    "jsdom": "^29.1.0",
    "marked": "^18.0.6",
    "papaparse": "^5.5.3",
    "playwright": "1.56.0",
    "subtlex-word-frequencies": "^2.0.0",
    "tabulator-tables": "^6.4.0"
  }
}
